general {
        output_format = "i3bar"
        colors = false
        interval = 5
}

order += "path_exists qwerty"
order += "path_exists wireguard"
order += "wireless _first_"
order += "volume master"
order += "path_exists radio_lofi"
order += "path_exists radio_sympa"
order += "battery all"
order += "tztime local"

battery all {
        integer_battery_capacity = true
        format = "%status%percentage"
        status_chr = "󱐋 "
        status_bat = "󰁿 "
        status_full = "󰁹 "
        last_full_capacity = true
}

tztime local {
        format = "%a %d %b  %H:%M "
}

volume master {
        format = "󰕾"
        format_muted = "󰝟"
        device = "default"
        mixer = "Master"
        mixer_idx = 0
}

wireless _first_ {
        format_up = "󰖩 %essid"
        format_down = "󰖪"
}

path_exists wireguard {
    path = "/proc/sys/net/ipv4/conf/wg-home"
    format = " wg-home"
    format_down = ""
}

path_exists radio_lofi {
    path = "/tmp/music_lofi"
    format = " Lofi"
    format_down = ""
}

path_exists radio_sympa {
    path = "/tmp/music_radio_sympa"
    format = " Sympa"
    format_down = ""
}

path_exists qwerty {
    path = "/tmp/kbmap-qwerty"
    format = "  US"
    format_down = ""
}
